  "linux": {
    "default_profile": "standard",
    "profiles": {
      "quick": [
        "System", "Process", "Network", "SystemdUnits", "Cron",
        "Accounts", "SshKeys"
      ],
      "standard": [
        "System", "Process", "Network", "SystemdUnits", "Cron",
